# ─────────────────────────────────────────────────────────────────
# CloudSense — Backend Environment Variables
# Copy to .env and fill in values before starting the server.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── Security ──────────────────────────────────────────────────────
# REQUIRED. Minimum 32 characters.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-with-a-long-random-secret-minimum-32-chars

# JWT token lifetime in hours (default: 24)
JWT_EXPIRATION_HOURS=24

# ── Database ──────────────────────────────────────────────────────
# SQLite (default for local dev — no setup required):
# DATABASE_URL=sqlite:///./cloudsense.db
#
# Neon PostgreSQL (production):
DATABASE_URL=sqlite:///./cloudsense.db

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# ── ML Model ──────────────────────────────────────────────────────
# Path to the trained U-Net weights file.
MODEL_PATH=../model/best_model.pth

# ── File Upload ───────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=500

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30

# ── Google OAuth (optional) ───────────────────────────────────────
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
